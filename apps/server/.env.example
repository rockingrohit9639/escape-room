SESSION_COOKIE_MAX_AGE=

# Storage
STORAGE_ENDPOINT=
STORAGE_PORT=
STORAGE_USE_SSL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=

# Server
SERVER_URL=http://localhost:3000/api